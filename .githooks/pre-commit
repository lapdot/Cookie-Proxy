#!/bin/sh

set -u

run_check() {
  command_name=$1

  printf '\n[pre-commit] Running %s\n' "$command_name"
  sh -c "$command_name"
  status=$?
  if [ "$status" -ne 0 ]; then
    printf '\n[pre-commit] Failed: %s\n' "$command_name" >&2
    printf '[pre-commit] Commit blocked because a required test command failed.\n' >&2
    exit "$status"
  fi
}

run_check "npm test"

printf '\n[pre-commit] All required test commands passed.\n'
